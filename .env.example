# ─── Database ─────────────────────────────────────────────────────────────────
# MySQL connection string
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=mysql://user:password@localhost:3306/bizdoc_consult

# ─── Authentication ───────────────────────────────────────────────────────────
# Secret key used to sign JWT tokens (use a long random string in production)
JWT_SECRET=change-this-to-a-long-random-secret

# Open ID of the platform owner/founder account (used for founder-only access checks)
OWNER_OPEN_ID=founder-open-id

# ─── Qwen / Model Studio (Primary — v7 chat) ────────────────────────────────
# API key from https://dashscope.aliyuncs.com/ — model: qwen3.5-plus
# DASHSCOPE_API_KEY is the v7 primary key name; QWEN_API_KEY also works as fallback
DASHSCOPE_API_KEY=your-dashscope-api-key
QWEN_API_KEY=your-qwen-api-key
QWEN_MODEL=qwen3.5-plus

# ─── Anthropic AI (Claude) — fallback if no Qwen key is set ─────────────────
# API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key

# ─── Chat v7 Feature Flags ──────────────────────────────────────────────────
CHAT_STREAMING=true
ENABLE_DASHBOARD_CHAT=true
ENABLE_PAYMENT_RECEIPT_UPLOAD=true
ENABLE_URL_REFERRAL_CAPTURE=true

# ─── Forge API (legacy — no longer used for AI) ───────────────────────────────
BUILT_IN_FORGE_API_KEY=your-forge-api-key
BUILT_IN_FORGE_API_URL=https://forge.butterfly-effect.dev

# ─── Server ───────────────────────────────────────────────────────────────────
# Port the Express server listens on (defaults to 3000 if not set)
PORT=3000

# Node environment
NODE_ENV=development

# ─── Bank Transfer Details (shown to clients on invoices) ────────────────────
BANK_NAME=MONIEPOINT
BANK_ACCOUNT_NUMBER=8034620520
BANK_ACCOUNT_NAME=Hamzury Ltd.
BIZDOC_BANK_NAME=MONIEPOINT
BIZDOC_BANK_ACCOUNT_NUMBER=8067149356
BIZDOC_BANK_ACCOUNT_NAME=BIZDOC LTD

# ─── Email (SMTP) — set when hamzury.com emails are ready ─────────────────────
# For Gmail: enable 2FA, then generate an App Password at myaccount.google.com/apppasswords
# For custom domain: use your provider's SMTP settings (e.g. Zoho, Google Workspace)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=info@hamzury.com
SMTP_PASS=your-app-password-here
ALERT_EMAIL=finance@hamzury.com

# ─── Notifications ────────────────────────────────────────────────────────
CSO_NOTIFY_PHONE=2348067149356   # WhatsApp number to receive payment alerts
TERMII_API_KEY=                  # Optional: Termii API key for SMS/WhatsApp alerts (get at termii.com)
CHAT_EVENTS_TOKEN=               # Bearer token for /api/events/* webhook endpoints (leave empty to disable auth in dev)

# ─── Client Credentials Encryption ───────────────────────────────────────────
# 32-character key used to AES-256-GCM encrypt stored client credentials
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex').slice(0,32))"
# IMPORTANT: Never share or commit the real key. Changing it invalidates all stored credentials.
CREDENTIALS_KEY=your-32-char-encryption-key-here
